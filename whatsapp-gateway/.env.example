# Port the gateway listens on
PORT=8090

# Shared secret — must match the "Gateway Secret" saved in the Laravel admin (Settings › WhatsApp API)
GATEWAY_SECRET=change-me-to-a-long-random-string

# Where to push inbound messages / connection events (Laravel API)
LARAVEL_WEBHOOK=https://deskadmin.razinsoft.com/api/whatsapp/gateway

# Folder to persist the WhatsApp auth session (keep this outside version control)
SESSION_DIR=./session
